#!/bin/sh
set -eu

if ! command -v git >/dev/null 2>&1; then
    exit 0
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -z "$repo_root" ]; then
    exit 0
fi

cd "$repo_root"

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged_files" ]; then
    exit 0
fi

needs_tidy=false
for path in $staged_files; do
    case "$path" in
        *.go|go.mod|go.sum|e2e/go.mod|e2e/go.sum|pkg/client/go.mod|pkg/client/go.sum|pkg/operator/go.mod|pkg/operator/go.sum|pkg/libaf/go.mod|pkg/libaf/go.sum|pkg/docsaf/go.mod|pkg/docsaf/go.sum|pkg/evalaf/go.mod|pkg/evalaf/go.sum|pkg/evalaf/plugins/antfly/go.mod|pkg/evalaf/plugins/antfly/go.sum|pkg/genkit/antfly/go.mod|pkg/genkit/antfly/go.sum|pkg/genkit/openrouter/go.mod|pkg/genkit/openrouter/go.sum)
            needs_tidy=true
            break
            ;;
    esac
done

if [ "$needs_tidy" != "true" ]; then
    exit 0
fi

echo "Running make tidy-check..."
if ! make tidy-check; then
    cat <<'EOF'
Go module files are out of sync.
Run `make tidy` and re-stage the updated go.mod/go.sum files before committing.
EOF
    exit 1
fi
