{
  "openapi": "3.1.0",
  "info": {
    "title": "Petstore 3.1",
    "version": "1.0.0"
  },
  "paths": {
    "/pets": {
      "get": {
        "operationId": "listPets",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of pets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Pet" }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewPet" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pet created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Pet" }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "petAdopted": {
      "post": {
        "operationId": "onPetAdopted",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Pet" }
            }
          }
        },
        "responses": {
          "200": { "description": "Acknowledged" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PetStatus": {
        "type": "string",
        "enum": ["available", "pending", "adopted"]
      },
      "Pet": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string", "minLength": 1 },
          "tag": {
            "type": ["string", "null"],
            "description": "Optional tag for categorization"
          },
          "status": { "$ref": "#/components/schemas/PetStatus" },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "NewPet": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "title": "Pet Name",
            "minLength": 1,
            "maxLength": 100
          },
          "tag": {
            "type": ["string", "null"]
          },
          "status": {
            "$ref": "#/components/schemas/PetStatus",
            "description": "Initial status (defaults to available)"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error", "message", "details"],
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "details": {
            "type": ["object", "null"],
            "additionalProperties": true,
            "description": "Required but nullable error details"
          }
        }
      }
    }
  }
}
