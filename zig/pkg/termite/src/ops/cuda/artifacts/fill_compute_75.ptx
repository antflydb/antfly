    div.u32 %r9, %r7, %r3;
    rem.u32 %r10, %r7, %r3;
    mov.u32 %r11, 0;
    mov.f32 %f1, 0f00000000;

LINEAR_LOOP:
    setp.ge.u32 %p2, %r11, %r2;
    @%p2 bra LINEAR_STORE;
    mad.lo.u32 %r12, %r9, %r2, %r11;
    mul.wide.u32 %rd4, %r12, 4;
    add.s64 %rd5, %rd2, %rd4;
    ld.global.f32 %f2, [%rd5];
    mad.lo.u32 %r13, %r10, %r2, %r11;
    mul.wide.u32 %rd6, %r13, 4;
    add.s64 %rd7, %rd3, %rd6;
    ld.global.f32 %f3, [%rd7];
    fma.rn.f32 %f1, %f2, %f3, %f1;
    add.u32 %r11, %r11, 1;
    bra LINEAR_LOOP;

