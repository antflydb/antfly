    mov.u32 %r3, %ctaid.x;
    setp.ge.u32 %p1, %r3, %r1;
    @%p1 bra RMS_DONE;

    mov.u32 %r4, 0;
    mov.f32 %f1, 0f00000000;
RMS_SUM_LOOP:
    setp.ge.u32 %p2, %r4, %r2;
    @%p2 bra RMS_SCALE;
    mad.lo.u32 %r5, %r3, %r2, %r4;
    mul.wide.u32 %rd4, %r5, 4;
    add.s64 %rd5, %rd2, %rd4;
    ld.global.f32 %f2, [%rd5];
    fma.rn.f32 %f1, %f2, %f2, %f1;
    add.u32 %r4, %r4, 1;
    bra RMS_SUM_LOOP;

RMS_SCALE:
    cvt.rn.f32.u32 %f3, %r2;
    div.rn.f32 %f4, %f1, %f3;
    add.rn.f32 %f5, %f4, %f8;
    sqrt.rn.f32 %f9, %f5;
    div.rn.f32 %f6, 0f3f800000, %f9;
    mov.u32 %r6, 0;
RMS_WRITE_LOOP:
    setp.ge.u32 %p3, %r6, %r2;
    @%p3 bra RMS_DONE;
    mad.lo.u32 %r7, %r3, %r2, %r6;
    mul.wide.u32 %rd6, %r7, 4;
    add.s64 %rd7, %rd2, %rd6;
    ld.global.f32 %f2, [%rd7];
    mul.wide.u32 %rd8, %r6, 4;
    add.s64 %rd9, %rd3, %rd8;
    ld.global.f32 %f7, [%rd9];
    mul.rn.f32 %f9, %f2, %f6;
    mul.rn.f32 %f9, %f9, %f7;
    add.s64 %rd10, %rd1, %rd6;
    st.global.f32 [%rd10], %f9;
    add.u32 %r6, %r6, 1;
    bra RMS_WRITE_LOOP;
