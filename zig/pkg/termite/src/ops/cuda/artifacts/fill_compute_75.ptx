    .param .u32 termite_elementwise_f32_param_3,
    .param .u32 termite_elementwise_f32_param_4
)
{
    .reg .pred %p<5>;
    .reg .f32 %f<8>;
    .reg .b32 %r<8>;
    .reg .b64 %rd<10>;

    ld.param.u64 %rd1, [termite_elementwise_f32_param_0];
    ld.param.u64 %rd2, [termite_elementwise_f32_param_1];
    ld.param.u64 %rd3, [termite_elementwise_f32_param_2];
    ld.param.u32 %r1, [termite_elementwise_f32_param_3];
    ld.param.u32 %r2, [termite_elementwise_f32_param_4];
    mov.u32 %r3, %ctaid.x;
    mov.u32 %r4, %ntid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r6, %r3, %r4, %r5;
    setp.ge.u32 %p1, %r6, %r1;
    @%p1 bra ELEM_DONE;

    mul.wide.u32 %rd4, %r6, 4;
    add.s64 %rd5, %rd2, %rd4;
    ld.global.f32 %f1, [%rd5];
    setp.eq.u32 %p2, %r2, 2;
    @%p2 bra ELEM_SILU;

    add.s64 %rd6, %rd3, %rd4;
    ld.global.f32 %f2, [%rd6];
    setp.eq.u32 %p3, %r2, 1;
    @%p3 bra ELEM_MUL;
    add.rn.f32 %f3, %f1, %f2;
    bra ELEM_STORE;

ELEM_MUL:
    mul.rn.f32 %f3, %f1, %f2;
    bra ELEM_STORE;

ELEM_SILU:
    neg.f32 %f4, %f1;
    mul.rn.f32 %f5, %f4, 0f3fb8aa3b;
    ex2.approx.ftz.f32 %f6, %f5;
    add.rn.f32 %f7, %f6, 0f3f800000;
    div.rn.f32 %f3, %f1, %f7;

ELEM_STORE:
    add.s64 %rd7, %rd1, %rd4;
    st.global.f32 [%rd7], %f3;
ELEM_DONE:
    ret;
