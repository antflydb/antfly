{
  "recipe": "grpo",
  "model": {
    "name": "scalar-grpo-smoke",
    "family": "preference"
  },
  "dataset": {
    "path": "pkg/inference/testdata/grpo_scalar.jsonl",
    "format": "token-logprobs"
  },
  "grpo": {
    "group_size": 2,
    "clip_epsilon": 0.2,
    "kl_coef": 0.04,
    "normalize_advantage": true
  },
  "optimizer": {
    "epochs": 1,
    "learning_rate": 0.0
  },
  "artifacts": {
    "root": "/tmp/termite-grpo-recipe-smoke"
  }
}
